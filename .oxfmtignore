# oxfmt formats YAML / JSON / Markdown. Exclude files that are generated,
# vendored, tool-owned, or explicitly outside this task's editable surface.

# Tool-owned changelogs / release metadata
changelog/
.release-please-manifest.json

# Build and vendored output
dist/
vendor/

# OMO working state and agent/index internals
.omo/
.git/
.codegraph/
.kiro/
